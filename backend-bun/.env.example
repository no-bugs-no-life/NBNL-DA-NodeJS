# ==========================================
# Application Configuration
# ==========================================

# Environment mode: development, production, or test
NODE_ENV=development

# Server Port
PORT=3000

# Logging level: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# ==========================================
# Infrastructure Configuration
# ==========================================

# PostgreSQL Database Connection URL (Required)
# Example: postgresql://postgres:password123@localhost:5432/bun_app
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Redis Connection URL
REDIS_URL=redis://localhost:6379

# ==========================================
# Security Configuration
# ==========================================

# JWT Access Secret and Expiration (Seconds, Default: 900 for 15 mins)
JWT_ACCESS_SECRET=super-secret-access-key-dev
JWT_ACCESS_EXPIRES_IN=900

# JWT Refresh Secret and Expiration (Seconds, Default: 604800 for 7 days)
JWT_REFRESH_SECRET=super-secret-refresh-key-dev
JWT_REFRESH_EXPIRES_IN=604800

# CORS Allowed Origin (Default is * for development)
# Example: http://localhost:3000, https://myapp.com
CORS_ORIGIN=*
