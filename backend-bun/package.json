{
  "name": "bun-example-source",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "lint": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "seed": "bun run src/scripts/seeds/index.ts",
    "migrate:apps:unset-rating": "bun run src/scripts/migrations/unsetAppRatingFields.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "latest",
    "pino-pretty": "^13.1.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "bcryptjs": "^3.0.3",
    "hono": "^4.12.11",
    "ioredis": "^5.10.1",
    "mongoose": "^9.4.1",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  }
}